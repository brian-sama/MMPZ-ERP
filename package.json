{
    "name": "mmpz-system-root",
    "version": "1.0.0",
    "description": "MMPZ System with unified development environment",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "api": "node server.js",
        "client": "cd client && npm run dev",
        "build": "cd client && npm run build",
        "dev": "npm run db:dev && concurrently --kill-others-on-fail \"npm run api\" \"npm run client\" --names \"API,VITE\" --prefix-colors \"cyan,magenta\"",
        "dev:app": "concurrently --kill-others-on-fail \"npm run api\" \"npm run client\" --names \"API,VITE\" --prefix-colors \"cyan,magenta\"",
        "db:dev": "node scripts/db_ensure.js",
        "db:up": "node scripts/docker_compose.js up -d",
        "db:down": "node scripts/docker_compose.js down",
        "db:migrate": "node scripts/db_migrate.js",
        "db:migrate:all": "node scripts/db_migrate_all.js",
        "db:seed": "node scripts/db_seed.js",
        "db:reset": "node scripts/db_reset.js"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "dependencies": {
        "postgres": "^3.4.3",
        "axios": "^1.6.2",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^17.2.3",
        "express": "^5.2.1"
    }
}
