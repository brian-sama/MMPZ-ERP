# Shared database URL (legacy scripts + Django)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mmpz_erp_local?sslmode=disable

# Django backend
DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
USE_REDIS_CACHE=false
REDIS_URL=redis://127.0.0.1:6379/0

# Optional explicit DB values (used when DATABASE_URL is absent)
DB_NAME=mmpz_erp_local
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
