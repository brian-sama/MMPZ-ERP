# Shared database URL (legacy scripts + local tooling)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mmpz_erp_local?sslmode=disable
MMPZ_AUTH_SECRET=replace-with-a-long-random-secret
MMPZ_DB_USER=postgres
MMPZ_DB_PASSWORD=replace-with-strong-db-password
MMPZ_DB_NAME=mmpz_erp_local
RUN_DB_MIGRATIONS_ON_STARTUP=false

# Django backend
DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
USE_REDIS_CACHE=false
REDIS_URL=redis://127.0.0.1:6379/0

# Optional explicit DB values (used when DATABASE_URL is absent)
DB_NAME=mmpz_erp_local
DB_USER=postgres
DB_PASSWORD=replace-with-strong-db-password
DB_HOST=localhost
DB_PORT=5432
