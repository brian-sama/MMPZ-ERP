# Django core
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
ALLOW_DJANGO_ADMIN=1

# API/browser security
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
USE_SECURE_PROXY_SSL_HEADER=1
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=0
SECURE_HSTS_PRELOAD=0

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=mmpz_erp_local
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis/cache/channels/celery
REDIS_URL=redis://127.0.0.1:6379/0
USE_REDIS_CACHE=0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@mmpz.local

# Production example for intranet.mmpzmne.co.zw
# DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=intranet.mmpzmne.co.zw
# CORS_ALLOWED_ORIGINS=https://intranet.mmpzmne.co.zw
# CSRF_TRUSTED_ORIGINS=https://intranet.mmpzmne.co.zw
# SECURE_SSL_REDIRECT=1
# SESSION_COOKIE_SECURE=1
# CSRF_COOKIE_SECURE=1
# ALLOW_DJANGO_ADMIN=0
