[Unit]
Description=Unified Portal Daphne (ASGI/WebSocket)
After=network.target redis.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/unified-enterprise-portal/platform/backend
EnvironmentFile=/etc/unified-portal/backend.env
ExecStart=/opt/unified-enterprise-portal/platform/backend/venv/bin/daphne -b 127.0.0.1 -p 8001 config.asgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
