[Unit]
Description=Unified Portal Celery Beat
After=network.target redis.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/unified-enterprise-portal/platform/backend
EnvironmentFile=/etc/unified-portal/backend.env
ExecStart=/opt/unified-enterprise-portal/platform/backend/venv/bin/celery -A config beat --loglevel=INFO
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
